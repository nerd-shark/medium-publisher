          <mxGeometry x="1386" y="145" width="180" height="200" as="geometry" />
        </mxCell>
        <mxCell id="summary_bar" value="&lt;b&gt;Each layer protects against different failure modes. No single layer is sufficient.&lt;/b&gt; If Layer 1 misses something, Layer 2 catches it. If Layer 2 misses, Layer 3. Defense in depth means multiple independent safety nets." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontSize=12;fontColor=#333333;align=center;" parent="1" vertex="1">
