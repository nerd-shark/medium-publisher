        <mxCell id="arr_23" value="&lt;font style=&quot;font-size:10px&quot;&gt;~80%&amp;nbsp;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size:10px&quot;&gt;passes&lt;/font&gt;&lt;/div&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=3;strokeColor=#1565c0;endArrow=classic;endFill=1;exitX=0.999;exitY=0.446;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0;entryY=0.446;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" edge="1" target="layer3" source="layer2">
