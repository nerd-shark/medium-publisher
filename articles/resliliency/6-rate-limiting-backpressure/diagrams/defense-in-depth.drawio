  <diagram id="defense-in-depth" name="Defense in Depth: Rate Limiting at Every Layer">
    <mxGraphModel dx="3650" dy="1104" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
