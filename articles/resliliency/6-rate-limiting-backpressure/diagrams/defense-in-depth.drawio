        <mxCell id="l1_title" value="&lt;b&gt;LAYER 1&lt;/b&gt;&lt;br&gt;Edge / CDN / WAF" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=14;fontColor=#c62828;" parent="1" vertex="1">
          <mxGeometry x="230" y="90" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l1_detail" value="&lt;font style=&quot;font-size:11px&quot;&gt;• Per-IP rate limiting&lt;br&gt;• DDoS mitigation&lt;br&gt;• Bot detection &amp;amp; filtering&lt;br&gt;• Geo-blocking&lt;br&gt;• TLS termination&lt;br&gt;&lt;br&gt;&lt;b&gt;Tools:&lt;/b&gt;&lt;br&gt;Cloudflare, AWS Shield,&lt;br&gt;AWS WAF, Akamai&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=12;fontColor=#333333;" parent="1" vertex="1">
