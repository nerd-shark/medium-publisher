        <mxCell id="l2_title" value="&lt;b&gt;LAYER 2&lt;/b&gt;&lt;br&gt;API Gateway" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=14;fontColor=#e65100;" parent="1" vertex="1">
          <mxGeometry x="510" y="90" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l2_detail" value="&lt;font style=&quot;font-size:11px&quot;&gt;• Per-client rate limiting&lt;br&gt;&amp;nbsp;&amp;nbsp;(API key / OAuth token)&lt;br&gt;• Business-level limits&lt;br&gt;&amp;nbsp;&amp;nbsp;Free: 100 req/min&lt;br&gt;&amp;nbsp;&amp;nbsp;Paid: 10,000 req/min&lt;br&gt;• Authentication &amp;amp; authz&lt;br&gt;• Request validation&lt;br&gt;&lt;br&gt;&lt;b&gt;Tools:&lt;/b&gt;&lt;br&gt;Kong, AWS API GW,&lt;br&gt;Apigee, Envoy&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=12;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="515" y="145" width="175" height="200" as="geometry" />
        </mxCell>
        <mxCell id="l2_blocks" value="&lt;b&gt;🚫 Blocks:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Unauthenticated requests&lt;br&gt;Over-limit clients&lt;br&gt;Invalid requests&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e67e22;strokeWidth=1;fontSize=11;fontColor=#e65100;" parent="1" vertex="1">
          <mxGeometry x="515" y="340" width="170" height="80" as="geometry" />
