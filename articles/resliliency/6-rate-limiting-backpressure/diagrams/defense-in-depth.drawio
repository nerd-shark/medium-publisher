        </mxCell>
        <mxCell id="l4_title" value="&lt;b&gt;LAYER 4&lt;/b&gt;&lt;br&gt;Application" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=14;fontColor=#2e7d32;" parent="1" vertex="1">
