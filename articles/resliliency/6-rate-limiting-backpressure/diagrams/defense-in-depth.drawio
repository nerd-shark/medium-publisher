        </mxCell>
        <mxCell id="l4_detail" value="&lt;font style=&quot;font-size:11px&quot;&gt;• Bounded queues&lt;br&gt;• Connection pool limits&lt;br&gt;• Thread pool limits&lt;br&gt;• Priority queuing&lt;br&gt;• Load shedding&lt;br&gt;• Graceful degradation&lt;br&gt;&lt;br&gt;&lt;b&gt;Last line of defense&lt;/b&gt;&lt;br&gt;Prevents resource&lt;br&gt;exhaustion&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=12;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="1104" y="145" width="172" height="200" as="geometry" />
        </mxCell>
        <mxCell id="l4_blocks" value="&lt;b&gt;🚫 Blocks:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Resource exhaustion&lt;br&gt;Unbounded queues&lt;br&gt;Low-priority work (shed)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=1;fontSize=11;fontColor=#1b5e20;" parent="1" vertex="1">
