        <mxCell id="l3_title" value="&lt;b&gt;LAYER 3&lt;/b&gt;&lt;br&gt;Service Mesh" style="text;html=1;align=center;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=14;fontColor=#1565c0;" parent="1" vertex="1">
          <mxGeometry x="800" y="90" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="l3_detail" value="&lt;font style=&quot;font-size:11px&quot;&gt;• Per-service rate limiting&lt;br&gt;&amp;nbsp;&amp;nbsp;(A → B: 1,000 req/s)&lt;br&gt;• Circuit breakers&lt;br&gt;• Retry budgets&lt;br&gt;• Load balancing&lt;br&gt;• Timeout enforcement&lt;br&gt;&lt;br&gt;&lt;b&gt;Tools:&lt;/b&gt;&lt;br&gt;Istio, Linkerd, Envoy,&lt;br&gt;AWS App Mesh&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontSize=12;fontColor=#333333;" parent="1" vertex="1">
          <mxGeometry x="805" y="145" width="175" height="200" as="geometry" />
        </mxCell>
        <mxCell id="l3_blocks" value="&lt;b&gt;🚫 Blocks:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Internal cascade failures&lt;br&gt;Service-to-service overload&lt;br&gt;Retry storms&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1;fontSize=11;fontColor=#0d47a1;" parent="1" vertex="1">
