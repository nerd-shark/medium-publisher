<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.0.3 Chrome/140.0.7339.249 Electron/38.7.0 Safari/537.36" version="29.0.3">
  <diagram id="retry-storm" name="The Retry Storm Death Spiral">
    <mxGraphModel dx="1025" dy="552" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="step1" value="&lt;b&gt;Traffic Spike&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;10x normal load&lt;br&gt;(Black Friday, viral post,&lt;br&gt;marketing campaign)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="560" y="100" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;Response Times Climb&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;200ms → 2s → 10s → 45s&lt;br&gt;Requests hold resources longer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="790" y="230" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;Resources Saturate&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;CPU 100% • Memory full&lt;br&gt;Connection pools exhausted&lt;br&gt;Thread pools blocked&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;fontSize=13;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="790" y="360" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;Users &amp;amp; Clients Retry&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Users refresh pages (2x load)&lt;br&gt;Mobile apps auto-retry (3x load)&lt;br&gt;Upstream services retry&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=13;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="540" y="480" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="&lt;b&gt;Auto-Scaling Too Slow&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;3-5 min to provision&lt;br&gt;Cascade already started&lt;br&gt;New instances overwhelmed too&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=13;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="270" y="370" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="&lt;b&gt;💀 TOTAL FAILURE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;OOM crashes • Service down&lt;br&gt;Cascading failures across&lt;br&gt;all dependent services&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6194b;strokeColor=#990000;strokeWidth=3;fontSize=13;fontColor=#ffffff;verticalAlign=middle;spacingTop=5;spacingBottom=5;" parent="1" vertex="1">
          <mxGeometry x="270" y="230" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#6c8ebf;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" parent="1" source="step1" target="step2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#d6b656;endArrow=classic;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="step2" target="step3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#d79b00;endArrow=classic;endFill=1;exitX=0.5;exitY=1;entryX=1;entryY=0.5;exitDx=0;exitDy=0;" parent="1" source="step3" target="step4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#b85450;endArrow=classic;endFill=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" parent="1" source="step4" target="step5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#b85450;endArrow=classic;endFill=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" parent="1" source="step5" target="step6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_feedback" value="&lt;b&gt;FEEDBACK LOOP&lt;/b&gt;&lt;br&gt;Retries become new traffic" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#cc0000;endArrow=classic;endFill=1;dashed=1;dashPattern=8 4;exitX=0.5;exitY=0;entryX=0.455;entryY=0.978;fontSize=11;fontColor=#cc0000;labelBackgroundColor=#ffffff;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" source="step4" target="step1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="480" />
              <mxPoint x="650" y="360" />
              <mxPoint x="651" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="break_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;dashed=1;dashPattern=8 4;opacity=70;" parent="1" vertex="1">
          <mxGeometry x="460" y="590" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="break_label" value="&lt;b&gt;✅ RATE LIMITING BREAKS THE LOOP&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;• Reject excess traffic &lt;i&gt;before&lt;/i&gt; it enters the system&lt;br&gt;• Return 429 + Retry-After → clients wait&lt;br&gt;• Backpressure propagates &quot;slow down&quot; through chain&lt;br&gt;• System stays alive, serves what it can&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#2d6a2e;" parent="1" vertex="1">
          <mxGeometry x="475" y="600" width="350" height="110" as="geometry" />
        </mxCell>
        <mxCell id="timeline" value="⏱ 10:00 AM → healthy &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp; 10:01 AM → degraded &amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp; 10:03 AM → dead" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=3;fontColor=#990000;" parent="1" vertex="1">
          <mxGeometry x="320" y="30" width="660" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
